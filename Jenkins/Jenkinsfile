pipeline {
    agent any

    environment {
        // Global variables and credentials
        DOCKER_HUB_CREDS = 'dockerhub-creds'
        AWS_CREDS_ID     = 'aws-credentials' 
        DOCKER_USER      = 'your_dockerhub_username'
        APP_NAME         = 'seyoawe-engine'
        APP_VERSION      = '' // Calculated dynamically
        EC2_IP           = '' // Will be populated by Terraform [cite:96][cite:101]
    }

    stages {
        stage('Initialize & Calculate Version') {
            steps {
                script {
                    // 1. List files so you can see the truth in the logs
                    sh "ls -R ${WORKSPACE}"
                    
                    // 2. Try to find the file in multiple common locations
                    if (fileExists("VERSION")) {
                        env.APP_VERSION = readFile("VERSION").trim()
                    } else if (fileExists("Jenkins/VERSION")) {
                        env.APP_VERSION = readFile("Jenkins/VERSION").trim()
                    } else {
                        // 3. If it's missing, don't crash; set a default so the build continues
                        echo "WARNING: VERSION file not found. Using default 1.0.0"
                        env.APP_VERSION = "1.0.0"
                    }
                    echo "Starting build for Global Version: ${env.APP_VERSION}"
                }
            }
        }

        // CI Phase - Parallel execution of Engine and CLI
        stage('Parallel CI Build & Test') {
            parallel {
                
                // ==========================================
                // ENGINE PIPELINE (Runs parallel to CLI)
                // ==========================================
                stage('Engine CI') {
                    when { changeset "engine/**" }
                    stages {
                        stage('Test Engine') {
                            steps {
                                dir('engine') {
                                    echo "Running Pytest for Engine..."
                                    sh '''
                                        python3 -m venv venv
                                        . venv/bin/activate
                                        pip install -r requirements.txt
                                        pip install pytest pytest-cov
                                        # Run tests and output results to XML for Jenkins
                                        pytest --junitxml=engine-test-results.xml
                                    '''
                                }
                            }
                            post {
                                always {
                                    // Publish test results to Jenkins UI even if tests fail
                                    junit 'engine/engine-test-results.xml'
                                }
                            }
                        }
                        stage('Build Engine Image') {
                            steps {
                                dir('engine') {
                                    echo "Building Docker image ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                    sh "docker build -t ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ."
                                }
                            }
                        }
                        stage('Push Engine Image') {
                            steps {
                                withCredentials([usernamePassword(credentialsId: env.DOCKER_HUB_CREDS, usernameVariable: 'DOCKER_USER_ID', passwordVariable: 'DOCKER_USER_PASS')]) {
                                    sh "echo \$DOCKER_USER_PASS | docker login -u \$DOCKER_USER_ID --password-stdin"
                                    sh "docker push ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                    sh "docker tag ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ${DOCKER_USER}/${APP_NAME}:latest"
                                    sh "docker push ${DOCKER_USER}/${APP_NAME}:latest"
                                }
                            }
                        }
                    }
                }

                // ==========================================
                // CLI PIPELINE (Runs parallel to Engine)
                // ==========================================
                stage('CLI CI') {
                    when { changeset "cli/**" }
                    stages {
                        stage('Test CLI') {
                            steps {
                                dir('cli') {
                                    echo "Running Pytest for CLI..."
                                    sh '''
                                        python3 -m venv venv
                                        . venv/bin/activate
                                        pip install -r requirements.txt
                                        pip install pytest pytest-cov
                                        # Run tests and output results to XML for Jenkins
                                        pytest --junitxml=cli-test-results.xml
                                    '''
                                }
                            }
                            post {
                                always {
                                    // Publish test results to Jenkins UI even if tests fail
                                    junit 'cli/cli-test-results.xml'
                                }
                            }
                        }
                        stage('Package CLI Artifact') {
                            steps {
                                dir('cli') {
                                    echo "Packaging CLI tool version ${env.APP_VERSION}"
                                    sh '''
                                        . venv/bin/activate
                                        python setup.py sdist bdist_wheel
                                    '''
                                }
                            }
                        }
                        stage('Publish CLI Artifact') {
                            steps {
                                echo "Publishing CLI artifact to Jenkins..."
                                archiveArtifacts artifacts: 'cli/dist/*', allowEmptyArchive: true
                            }
                        }
                    }
                }
            }
        }

        // --- CD: FREE TIER DEPLOYMENT (Replaced EKS logic) ---
        stage('Continuous Deployment (Free Tier)') {
            when { branch 'main' }
            stages {
                stage('Provision Free Tier EC2 (Terraform)') {
                    steps {
                        dir('terraform') {
                            withCredentials([aws(credentialsId: env.AWS_CREDS_ID)]) {
                                sh 'terraform init'
                                sh 'terraform apply -auto-approve'
                                // Retrieve the public IP of the newly created instance and assign it to Jenkins variable
                                script {
                                    env.EC2_IP = sh(script: 'terraform output -raw public_ip', returnStdout: true).trim()
                                    echo "✅ New EC2 Server created successfully at IP: ${env.EC2_IP}"
                                }
                            }
                        }
                    }
                }
                
                stage('Update K8s Manifests Locally') {
                    steps {
                        dir('k8s') {
                            echo "Injecting version ${env.APP_VERSION} into statefulset..."
                            // Update the image tag in the workspace BEFORE Ansible copies it to the server
                            sh "sed -i 's|your_dockerhub_username/seyoawe-engine:.*|${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}|g' statefulset.yaml"
                        }
                    }
                }

                stage('Install K3s & Deploy App (Ansible)') {
                    steps {
                        dir('ansible') {
                            // Wait a short time for the new Ubuntu server SSH daemon to fully boot up
                            sleep time: 30, unit: 'SECONDS'
                            
                            // Execute Ansible against the newly created EC2 instance over SSH
                            sh """
                                ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook \\
                                -i '${env.EC2_IP},' \\
                                -u ubuntu \\
                                --private-key ../terraform/k8s-key.pem \\
                                setup_k3s.yml
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up Jenkins workspace to save disk space..."
            cleanWs()
        }
    }
}