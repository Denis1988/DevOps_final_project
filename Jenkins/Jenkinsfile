pipeline {
    agent any

    environment {
        // Only non-secret configuration variables remain here
        APP_NAME    = 'seyoawe-engine'
        APP_VERSION = '' // Calculated dynamically
        EC2_IP      = '' // Populated dynamically by Terraform
    }

    stages {
        stage('Initialize & Calculate Version') {
            steps {
                script {
                    error "Intentional failure to test Jira ticket creation."
                    sh "ls -R ${WORKSPACE}"
                    if (fileExists("VERSION")) {
                        env.APP_VERSION = readFile("VERSION").trim()
                    } else if (fileExists("Jenkins/VERSION")) {
                        env.APP_VERSION = readFile("Jenkins/VERSION").trim()
                    } else {
                        echo "WARNING: VERSION file not found. Using default 1.0.0"
                        env.APP_VERSION = "1.0.0"
                    }
                    echo "Starting build for Global Version: ${env.APP_VERSION}"
                }
            }
        }

        // CI Phase - Parallel execution of Engine and CLI
        stage('Parallel CI Build & Test') {
            parallel {
                
                // --- ENGINE PIPELINE ---
                stage('Engine CI') {
                    when { changeset "engine/**" }
                    stages {
                        stage('Test Engine') {
                            steps {
                                dir('engine') {
                                    echo "Running Pytest for Engine..."
                                    sh '''
                                        python3 -m venv venv
                                        . venv/bin/activate
                                        pip install -r requirements.txt pytest pytest-cov
                                        pytest --junitxml=engine-test-results.xml
                                    '''
                                }
                            }
                            post { always { junit 'engine/engine-test-results.xml' } }
                        }
                        stage('Build & Push Engine Image') {
                            steps {
                                dir('engine') {
                                    // Retrieves Docker Hub credentials securely
                                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                                        echo "Building Docker image ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                        sh "docker build -t ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ."
                                        
                                        sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                                        sh "docker push ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                        sh "docker tag ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ${DOCKER_USER}/${APP_NAME}:latest"
                                        sh "docker push ${DOCKER_USER}/${APP_NAME}:latest"
                                    }
                                }
                            }
                        }
                    }
                }

                // --- CLI PIPELINE ---
                stage('CLI CI') {
                    when { changeset "cli/**" }
                    stages {
                        stage('Test CLI') {
                            steps {
                                dir('cli') {
                                    echo "Running Pytest for CLI..."
                                    sh '''
                                        python3 -m venv venv
                                        . venv/bin/activate
                                        pip install -r requirements.txt pytest pytest-cov
                                        pytest --junitxml=cli-test-results.xml
                                    '''
                                }
                            }
                            post { always { junit 'cli/cli-test-results.xml' } }
                        }
                        stage('Package & Publish CLI') {
                            steps {
                                dir('cli') {
                                    sh '. venv/bin/activate && python setup.py sdist bdist_wheel'
                                }
                                archiveArtifacts artifacts: 'cli/dist/*', allowEmptyArchive: true
                            }
                        }
                    }
                }
            }
        }

        // --- CD: FREE TIER DEPLOYMENT ---
        stage('Continuous Deployment (Free Tier)') {
            when { branch 'main' }
            stages {
                stage('Provision Free Tier EC2 (Terraform)') {
                    steps {
                        dir('terraform') {
                            // Retrieves AWS credentials securely
                            withCredentials([aws(credentialsId: 'aws-credentials')]) {
                                sh 'terraform init'
                                sh 'terraform apply -auto-approve'
                                script {
                                    env.EC2_IP = sh(script: 'terraform output -raw public_ip', returnStdout: true).trim()
                                    echo "✅ New EC2 Server created at IP: ${env.EC2_IP}"
                                }
                            }
                        }
                    }
                }
                
                stage('Update K8s Manifests Locally') {
                    steps {
                        dir('k8s') {
                            // Retrieves Docker username to correctly update the manifest file
                            withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                                sh "sed -i 's|your_dockerhub_username/seyoawe-engine:.*|${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}|g' statefulset.yaml"
                            }
                        }
                    }
                }

                stage('Install K3s & Deploy App (Ansible)') {
                    steps {
                        dir('ansible') {
                            sleep time: 30, unit: 'SECONDS'
                            sh """
                                ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook \\
                                -i '${env.EC2_IP},' \\
                                -u ubuntu \\
                                --private-key ../terraform/k8s-key.pem \\
                                setup_k3s.yml
                            """
                        }
                    }
                }
            }
        }
    }

    // --- PIPELINE STATUS HANDLING ---
    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ PIPELINE SUCCESS: Tests passed, images built, and successfully deployed to K3s!"
        }
        failure {
            echo "❌ PIPELINE FAILED: Automatically creating a Bug in Jira..."
            // Retrieves Jira API Token securely
            withCredentials([string(credentialsId: 'jira-api-token', variable: 'JIRA_TOKEN')]) {
                sh '''
                curl -X POST -H "Authorization: Basic ${JIRA_TOKEN}" \
                     -H "Content-Type: application/json" \
                     --data '{
                        "fields": {
                           "project": {"key": "DevOps project"},
                           "summary": "Jenkins Build Failed: '"${JOB_NAME}"' #'"${BUILD_NUMBER}"'",
                           "description": "Pipeline failed. Review the logs here: '"${BUILD_URL}"'",
                           "issuetype": {"name": "Bug"}
                        }
                     }' \
                     https://denis1988.atlassian.net?continue=https%3A%2F%2Fdenis1988.atlassian.net%2Fwelcome%2Fsoftware&atlOrigin=eyJpIjoiNWYyOGNmN2E3MTFjNDAyOWFiYjQwZDllNTVkMjk5MjAiLCJwIjoiaiJ9
                '''
            }
        }
    }
}