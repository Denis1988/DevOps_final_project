pipeline {
    agent any

    options 
    {
    buildDiscarder(logRotator(numToKeepStr: '5', artifactNumToKeepStr: '5'))
    disableConcurrentBuilds()
    }

    environment {
        // Core Variables
        APP_NAME    = 'seyoawe-engine'
        APP_VERSION = '' // Calculated dynamically
        EC2_IP      = '' // Relies on the terraform output file
        
        // Missing variables that were causing failures
        VENV_DIR    = 'venv' 
        repoName    = 'seyoawe-cli'
        githubUser  = 'your-github-username' // Update this with your actual GH user
    }

    stages {
        stage('Initialize & Calculate Version') {
            steps {
                script {
                    sh "ls -R ${WORKSPACE}"
                    if (fileExists("VERSION")) {
                        env.APP_VERSION = readFile("VERSION").trim()
                    } else if (fileExists("Jenkins/VERSION")) {
                        env.APP_VERSION = readFile("Jenkins/VERSION").trim()
                    } else {
                        echo "WARNING: VERSION file not found. Using default 1.0.0"
                        env.APP_VERSION = "1.0.0"
                    }
                    echo "Starting build for Global Version: ${env.APP_VERSION}"
                }
            }
        }

        // CI Phase - Parallel execution of Engine and CLI
        stage('Parallel CI Build & Test') {
            parallel {
                
                // --- ENGINE PIPELINE ---
                stage('Engine CI') {
                    stages {
                        stage('Test Engine') {
                            steps {
                                dir('.') {
                                    echo "Running Pytest for Engine..."
                                    sh 'docker rm -f seyoawe-engine-test || true'
                                    sh 'docker build -f docker/Dockerfile.engine_test -t seyoawe-engine-test .'
                                    sh 'mkdir -p reports'
                                    
                                    // If pytest fails, this returns exit code 1 and skips to post block
                                    sh 'docker run --name seyoawe-engine-test seyoawe-engine-test'
                                }
                            }
                            post { 
                                always { 
                                    // ALWAYS pull the report out, even if tests failed
                                    sh 'docker cp seyoawe-engine-test:/opt/seyoawe-engine/reports/seyoawe-engine.xml reports/ || true'
                                    junit 'reports/seyoawe-engine.xml' 
                                    sh 'docker rm -f seyoawe-engine-test || true'
                                } 
                            }
                        }

                stage('Build & Push Engine Image') {
            steps {
                dir('.') {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', 
                                        passwordVariable: 'DOCKER_PASS', 
                                        usernameVariable: 'DOCKER_USER_ID')]) {
                                        
                        echo "Building Docker image ${env.DOCKER_USER_ID}/${APP_NAME}:${env.BUILD_NUMBER}"
                        
                        sh "docker build -f docker/Dockerfile.engine_prod -t ${env.DOCKER_USER_ID}/${APP_NAME}:${env.BUILD_NUMBER} ."
                        
                        sh """
                            echo "=========================================="
                            echo "DEBUG: Verifying Docker Hub Credentials..."
                            echo "DEBUG: Attempting to authenticate to Docker Hub..."
                            echo "=========================================="
                            
                            echo \$DOCKER_PASS | docker login -u \$DOCKER_USER_ID --password-stdin
                            
                            echo "=========================================="
                            echo "DEBUG: Docker Login SUCCESS! Proceeding to push images..."
                            echo "=========================================="
                            
                            docker push ${env.DOCKER_USER_ID}/${APP_NAME}:${env.BUILD_NUMBER}
                            
                            docker tag ${env.DOCKER_USER_ID}/${APP_NAME}:${env.BUILD_NUMBER} ${env.DOCKER_USER_ID}/${APP_NAME}:latest
                            docker push ${env.DOCKER_USER_ID}/${APP_NAME}:latest
                        """
                    }
                }
            }
        }
                    }
                }

                // --- CLI PIPELINE ---
                stage('CLI CI') {
                    when { changeset "cli/**" }
                    stages {
                        stage('Test CLI') {
                            steps {
                                dir('.') {
                                    echo "Running Pytest for CLI inside Docker..."
                                    sh 'docker rm -f seyoawe-cli-test || true'
                                    sh 'docker build -f docker/Dockerfile.cli_test -t seyoawe-cli-test .'
                                    sh 'mkdir -p reports'
                                    
                                    // If pytest fails, this returns exit code 1 and skips to post block
                                    sh 'docker run --name seyoawe-cli-test seyoawe-cli-test'
                                }
                            }
                            post { 
                                always { 
                                    // ALWAYS pull the report out, even if tests failed
                                    sh 'docker cp seyoawe-cli-test:/opt/seyoawe-engine/reports/unit-tests.xml reports/ || true'
                                    junit 'reports/unit-tests.xml' 
                                    sh 'docker rm -f seyoawe-cli-test || true'
                                } 
                            }
                        }
                        stage('Package & Publish CLI') {
                            steps {
                                dir('.') {
                                    echo "Building CLI Production Image..."
                                    sh "docker build -f docker/Dockerfile.cli_prod -t ghcr.io/denis1988/seyoawe-cli:${env.BUILD_NUMBER} ."
                                    sh "docker tag ghcr.io/denis1988/seyoawe-cli:${env.BUILD_NUMBER} ghcr.io/denis1988/seyoawe-cli:latest"
                                    
                                    withCredentials([usernamePassword(credentialsId: 'github-creds', 
                                                        passwordVariable: 'GH_PAT', 
                                                        usernameVariable: 'GH_USER')]) {
                                        sh """
                                            echo "=========================================="
                                            echo "DEBUG: Verifying GitHub Credentials..."
                                            echo "DEBUG: The GitHub Username from Jenkins is: \$GH_USER"
                                            echo "DEBUG: Attempting to authenticate to ghcr.io..."
                                            echo "=========================================="
                                            
                                            # This command will fail if the token is wrong or missing write:packages
                                            echo \$GH_PAT | docker login ghcr.io -u \$GH_USER --password-stdin
                                            
                                            echo "=========================================="
                                            echo "DEBUG: Docker Login SUCCESS! Proceeding to push images..."
                                            echo "=========================================="
                                            
                                            docker push ghcr.io/denis1988/seyoawe-cli:${env.BUILD_NUMBER}
                                            docker push ghcr.io/denis1988/seyoawe-cli:latest
                                        """
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- CD: AWS FREE TIER DEPLOYMENT ---
        stage('Continuous Deployment') {
            stages {
                stage('Provision VM machine(Terraform)') {
                    steps {
                        dir('terraform') {
                            withCredentials([
                                string(credentialsId: 'aws-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                                string(credentialsId: 'aws-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                            ]) {
                                // Removed markdown formatting from the curl URL
                                sh '''
                                    echo "Downloading Terraform..."
                                    curl -sL https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_linux_amd64.zip -o terraform.zip
                                    python3 -c "import zipfile; zipfile.ZipFile('terraform.zip').extractall('.')"
                                    chmod +x terraform
                                    export PATH=$PATH:$(pwd)
                                    
                                    echo "Initializing Terraform..."
                                    terraform init
                                    
                                    echo "Applying Terraform..."
                                    terraform apply -auto-approve -parallelism=1
                                    
                                    echo "Extracting IP address..."
                                    terraform output -raw public_ip > ../ec2_ip.txt
                                    echo "✅ IP Saved to file: $(cat ../ec2_ip.txt)"
                                '''
                            }
                        }
                    }
                }

                stage('Install Ansible & Deploy App') {
                    steps {
                        dir('ansible') {
                            sleep time: 45, unit: 'SECONDS'
                            
                            script {
                                def TARGET_IP = readFile('../ec2_ip.txt').trim()
                                sh """
                                    echo "Installing Ansible..."
                                    python3 -m venv venv
                                    . venv/bin/activate
                                    pip install --upgrade pip
                                    pip install ansible
                                    
                                    echo "Running Ansible Playbook on IP: ${TARGET_IP}"
                                    ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook \\
                                    -i '${TARGET_IP},' \\
                                    -u ubuntu \\
                                    --private-key ../terraform/k8s-key.pem \\
                                    ansible.yml
                                """
                            }
                        }
                    }
                }
            }
        }
    }

    // --- PIPELINE STATUS HANDLING ---
    post {
        always {
            echo "Workspace preserved for Terraform State"
            echo "Cleaning up workspace to save disk space..."
            cleanWs()
        }
        success {
            echo "✅ PIPELINE SUCCESS: Tests passed, images built, and successfully deployed to K3s!"
        }
        failure {
            echo "❌ PIPELINE FAILED: Automatically creating a Bug in Jira..."
            withCredentials([usernameColonPassword(credentialsId: 'jira-api-token', variable: 'JIRA_AUTH')]) {
                // Removed markdown formatting from the Jira URL
                sh '''
                curl -s -X POST -u "$JIRA_AUTH" \
                     -H "Content-Type: application/json" \
                     --data '{
                        "fields": {
                           "project": {"key": "SCRUM"},
                           "summary": "Jenkins Build Failed: '"${JOB_NAME}"' #'"${BUILD_NUMBER}"'",
                           "description": "Pipeline failed. Review the logs here: '"${BUILD_URL}"'",
                           "issuetype": {"name": "Bug"}
                        }
                     }' \
                     https://denis1988.atlassian.net/rest/api/2/issue
                '''
            }
        }
    }
}