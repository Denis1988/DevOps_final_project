pipeline {
    agent any

    environment {
        // Core Variables
        APP_NAME    = 'seyoawe-engine'
        APP_VERSION = '' // Calculated dynamically
        EC2_IP      = '' // Relies on the terraform output file
        
        // Missing variables that were causing failures
        VENV_DIR    = 'venv' 
        repoName    = 'seyoawe-cli'
        githubUser  = 'your-github-username' // Update this with your actual GH user
    }

    stages {
        stage('Initialize & Calculate Version') {
            steps {
                script {
                    sh "ls -R ${WORKSPACE}"
                    if (fileExists("VERSION")) {
                        env.APP_VERSION = readFile("VERSION").trim()
                    } else if (fileExists("Jenkins/VERSION")) {
                        env.APP_VERSION = readFile("Jenkins/VERSION").trim()
                    } else {
                        echo "WARNING: VERSION file not found. Using default 1.0.0"
                        env.APP_VERSION = "1.0.0"
                    }
                    echo "Starting build for Global Version: ${env.APP_VERSION}"
                }
            }
        }

        // CI Phase - Parallel execution of Engine and CLI
        stage('Parallel CI Build & Test') {
            parallel {
                
                // --- ENGINE PIPELINE ---
                stage('Engine CI') {
                    stages {
                        stage('Test Engine') {
                            steps {
                                echo "Running Pytest for Engine..."
                                sh 'docker rm -f seyoawe-engine || true'
                                sh 'docker build -f docker/Dockerfile.engine_test -t seyoawe-engine .'
                                // Run the engine in the background so tests can hit localhost:5000
                                sh 'docker run -d -p 5000:5000 --name seyoawe-engine seyoawe-engine'
                                
                                sh 'mkdir -p reports'
                                // Create venv, install requirements, and run tests
                                sh """
                                    python3 -m venv ${VENV_DIR}
                                    . ${VENV_DIR}/bin/activate
                                    pip install -r requirements.txt
                                    pytest tests/engine_test.py -v --cov=app --cov-report=xml --cov-report=html --junit-xml=reports/seyoawe-engine.xml
                                """
                            }
                            post { 
                                always { 
                                    sh 'docker rm -f seyoawe-engine || true'
                                    junit 'reports/seyoawe-engine.xml' 
                                } 
                            }
                        }
                        stage('Build & Push Engine Image') {
                            steps {
                                dir('engine') {
                                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                                        echo "Building Docker image ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                        sh "docker build -t ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ."
                                        
                                        sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                                        sh "docker push ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION}"
                                        sh "docker tag ${DOCKER_USER}/${APP_NAME}:${env.APP_VERSION} ${DOCKER_USER}/${APP_NAME}:latest"
                                        sh "docker push ${DOCKER_USER}/${APP_NAME}:latest"
                                    }
                                }
                            }
                        }
                    }
                }

                                // --- CLI PIPELINE ---
                stage('CLI CI') {
                    stages {
                        stage('Test CLI') {
                            steps {
                                dir('cli') {
                                    echo "Running Pytest for CLI inside Docker..."
                                    
                                    // 1. Clean up old containers
                                    sh 'docker rm -f seyoawe-cli-test || true'
                                    
                                    // 2. Build the test image
                                    sh 'docker build -f ../docker/Dockerfile.cli_test -t seyoawe-cli-test .'
                                    
                                    // 3. Run the container. It will execute pytest (based on the CMD in Dockerfile)
                                    // We don't use -d (detached) because we want Jenkins to wait for tests to finish
                                    sh 'docker run --name seyoawe-cli-test seyoawe-cli-test'
                                    
                                    // 4. Create local reports directory
                                    sh 'mkdir -p reports'
                                    
                                    // 5. Copy the generated XML report OUT of the stopped container into Jenkins workspace
                                    sh 'docker cp seyoawe-cli-test:/opt/seyoawe-engine/reports/unit-tests.xml reports/'
                                }
                            }
                            post { 
                                always { 
                                    // Archive the test results using the copied file
                                    junit 'cli/reports/unit-tests.xml' 
                                    // Clean up the container
                                    sh 'docker rm -f seyoawe-cli-test || true'
                                } 
                            }
                        }
                        stage('Package & Publish CLI') {
                            steps {
                                dir('cli') {
                                    sh '. venv/bin/activate && python setup.py sdist bdist_wheel'
                                }
                                archiveArtifacts artifacts: 'cli/dist/*', allowEmptyArchive: true
                                
                                // GitHub Container Registry (ensure repoName is lowercase for GHCR)
                                withCredentials([usernamePassword(credentialsId: 'github-creds', 
                                                    passwordVariable: 'GH_PAT', 
                                                    usernameVariable: 'GH_USER')]) {
                                    sh """
                                        echo \$GH_PAT | docker login ghcr.io -u \$GH_USER --password-stdin
                                        docker tag ${repoName}:${env.BUILD_NUMBER} ghcr.io/${githubUser}/${repoName}:${env.BUILD_NUMBER}
                                        docker tag ${repoName}:${env.BUILD_NUMBER} ghcr.io/${githubUser}/${repoName}:latest
                                        docker push ghcr.io/${githubUser}/${repoName}:${env.BUILD_NUMBER}
                                        docker push ghcr.io/${githubUser}/${repoName}:latest
                                    """
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- CD: AWS FREE TIER DEPLOYMENT ---
        stage('Continuous Deployment') {
            stages {
                stage('Provision Free Tier VM (Terraform)') {
                    steps {
                        dir('terraform') {
                            withCredentials([
                                string(credentialsId: 'aws-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                                string(credentialsId: 'aws-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                            ]) {
                                // Removed markdown formatting from the curl URL
                                sh '''
                                    echo "Downloading Terraform..."
                                    curl -sL https://releases.hashicorp.com/terraform/1.7.5/terraform_1.7.5_linux_amd64.zip -o terraform.zip
                                    python3 -c "import zipfile; zipfile.ZipFile('terraform.zip').extractall('.')"
                                    chmod +x terraform
                                    export PATH=$PATH:$(pwd)
                                    
                                    echo "Initializing Terraform..."
                                    terraform init
                                    
                                    echo "Applying Terraform..."
                                    terraform apply -auto-approve -parallelism=1
                                    
                                    echo "Extracting IP address..."
                                    terraform output -raw public_ip > ../ec2_ip.txt
                                    echo "✅ IP Saved to file: $(cat ../ec2_ip.txt)"
                                '''
                            }
                        }
                    }
                }

                stage('Install Ansible & Deploy App') {
                    steps {
                        dir('ansible') {
                            sleep time: 45, unit: 'SECONDS'
                            
                            script {
                                def TARGET_IP = readFile('../ec2_ip.txt').trim()
                                sh """
                                    echo "Installing Ansible..."
                                    python3 -m venv venv
                                    . venv/bin/activate
                                    pip install --upgrade pip
                                    pip install ansible
                                    
                                    echo "Running Ansible Playbook on IP: ${TARGET_IP}"
                                    ANSIBLE_HOST_KEY_CHECKING=False ansible-playbook \\
                                    -i '${TARGET_IP},' \\
                                    -u ubuntu \\
                                    --private-key ../terraform/k8s-key.pem \\
                                    ansible.yml
                                """
                            }
                        }
                    }
                }
            }
        }
    }

    // --- PIPELINE STATUS HANDLING ---
    post {
        always {
            echo "Workspace preserved for Terraform State"
        }
        success {
            echo "✅ PIPELINE SUCCESS: Tests passed, images built, and successfully deployed to K3s!"
        }
        failure {
            echo "❌ PIPELINE FAILED: Automatically creating a Bug in Jira..."
            withCredentials([usernameColonPassword(credentialsId: 'jira-api-token', variable: 'JIRA_AUTH')]) {
                // Removed markdown formatting from the Jira URL
                sh '''
                curl -s -X POST -u "$JIRA_AUTH" \
                     -H "Content-Type: application/json" \
                     --data '{
                        "fields": {
                           "project": {"key": "SCRUM"},
                           "summary": "Jenkins Build Failed: '"${JOB_NAME}"' #'"${BUILD_NUMBER}"'",
                           "description": "Pipeline failed. Review the logs here: '"${BUILD_URL}"'",
                           "issuetype": {"name": "Bug"}
                        }
                     }' \
                     https://denis1988.atlassian.net/rest/api/2/issue
                '''
            }
        }
    }
}